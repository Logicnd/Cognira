# Cognira runtime environment template
# Copy to .env for local dev, or set these keys in Vercel Environment Variables.

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LOW_RESOURCE_MODE=true
NEXT_PUBLIC_DEFAULT_MODEL_LABEL=llama3 (Local)

# Core model routing
USE_LOCAL=true
DEFAULT_LOCAL_MODEL=llama3
ENABLE_CLOUD_MODELS=false
DEFAULT_MODEL=free
OLLAMA_URL=http://localhost:11434/api

# Free provider fallback (optional)
HF_INFERENCE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
HF_API_TOKEN=
FREE_MODEL_CANDIDATES=TinyLlama/TinyLlama-1.1B-Chat-v1.0,Qwen/Qwen2.5-1.5B-Instruct,google/flan-t5-base

# Billing / checkout provider abstraction
CHECKOUT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_BASE_URL=http://localhost:3000
STRIPE_SUCCESS_URL=http://localhost:3000/admin/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/admin/billing?checkout=cancelled
STRIPE_PRICE_ID_PLUS_MONTHLY=
STRIPE_PRICE_ID_PLUS_YEARLY=
STRIPE_PRICE_ID_BUSINESS_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_YEARLY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=

# API host
HOST=0.0.0.0
PORT=8000
