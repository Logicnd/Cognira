{
  "name": "cognira",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:frontend:lite": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-frontend-lite.ps1",
    "dev:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-backend.ps1",
    "dev:lite": "npm run dev:backend",
    "dev:ui:lite": "npm run dev:frontend:lite",
    "build": "next build",
    "start": "next start",
    "start:lite": "next start -p 3000",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
